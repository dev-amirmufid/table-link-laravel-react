        "/relations": {
            "get": {
                "tags": [
                    "Relations"
                ],
                "summary": "Buyer-Seller Relations",
                "description": "Returns top buyers and sellers by transaction count",
                "operationId": "0c30afdb06228e6ce831110300806be6",
                "parameters": [
                    {
                        "name": "type",
                        "in": "query",
                        "description": "Type: buyers, sellers, or both (default)",
                        "schema": {
                            "type": "string",
                            "default": "both",
                            "enum": [
                                "buyers",
                                "sellers",
                                "both"
                            ]
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Number of results (default 10)",
                        "schema": {
                            "type": "integer",
