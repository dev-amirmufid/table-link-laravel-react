        "/dashboard/cache/clear": {
            "post": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Clear dashboard cache",
                "description": "Clears all cached dashboard data",
                "operationId": "1c5aa259e6cad913c42c339223df6370",
                "responses": {
                    "200": {
                        "description": "Cache cleared successfully"
                    }
                }
            }
