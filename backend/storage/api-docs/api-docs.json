        "/dashboard/analytics": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Dashboard Analytics - God Query",
                "description": "Returns all dashboard data in a single request using CTE. Supports optional 'include' parameter to fetch specific data sections.",
                "operationId": "30ccd1fc1b8b451c1894c91ac42f2d75",
                "parameters": [
                    {
                        "name": "include",
                        "in": "query",
                        "description": "Comma-separated list of data to include: summary,trends,trending_items,user_classification,top_buyers,top_sellers. Default: all",
                        "schema": {
                            "type": "string",
                            "example": "summary,trends,trending_items"
                        }
                    },
                    {
                        "name": "period",
                        "in": "query",
                        "description": "Trends period: daily, weekly, monthly (default: daily)",
                        "schema": {
                            "type": "string",
                            "default": "daily",
                            "enum": [
                                "daily",
                                "weekly",
                                "monthly"
                            ]
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Limit for trending items and top users (default: 10)",
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    },
                    {
                        "name": "start_date",
                        "in": "query",
                        "description": "Start date (Y-m-d)",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "end_date",
                        "in": "query",
                        "description": "End date (Y-m-d)",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "user_type",
                        "in": "query",
                        "description": "User type: domestic, foreign",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "domestic",
                                "foreign"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation"
                    }
                }
            }
        },
        "/transactions": {
            "get": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Get all transactions",
                "description": "Returns paginated transactions",
                "operationId": "985f8d6a4ee65fbeaf1513cb4f53a3e8",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Page number",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Items per page (max 100)",
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Search by buyer name, seller name, or item name",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "start_date",
                        "in": "query",
                        "description": "Start date (Y-m-d H:i:s)",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "end_date",
                        "in": "query",
                        "description": "End date (Y-m-d H:i:s)",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation"
                    }
                }
            }
        },
        "/transactions/{id}": {
            "get": {
                "tags": [
                    "Transactions"
                ],
                "summary": "Get single transaction",
                "description": "Returns a single transaction by ID",
                "operationId": "0cef9d26f188e69308596914577e6835",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Transaction UUID",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation"
                    },
                    "404": {
                        "description": "Transaction not found"
                    }
                }
            }
