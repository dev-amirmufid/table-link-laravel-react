    "paths": {
        "/": {},
        "/dashboard/summary": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Dashboard KPI Summary",
                "description": "Returns total transactions, quantity, revenue, active buyers and sellers",
                "operationId": "86fabda7fcf823aa429b7ae8c5290e9d",
                "parameters": [
                    {
                        "name": "start_date",
                        "in": "query",
                        "description": "Start date (Y-m-d)",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "end_date",
                        "in": "query",
                        "description": "End date (Y-m-d)",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "user_type",
                        "in": "query",
                        "description": "User type: domestic, foreign",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "domestic",
                                "foreign"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation"
                    }
                }
            }
        },
